package templates

func baseHref(basePath string) string {
	if basePath == "" {
		return "/"
	}
	return basePath + "/"
}

templ Layout(title string, basePath string) {
	<!DOCTYPE html>
	<html lang="ru">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ title } — TalmorGo</title>
			<base href={ baseHref(basePath) }/>
			<!-- Google Material Symbols -->
			<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=block"/>
			<link rel="stylesheet" href="static/plyr.min.css"/>
			<script src="static/htmx.min.js"></script>
			<script src="static/plyr.min.js"></script>
			<style>
				*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

				/* ── Material 3 Color Tokens (Dark theme) ── */
				:root {
					--m3-bg:          #0f0f11;
					--m3-surface:     #1a1a1f;
					--m3-surface-var: #252530;
					--m3-surface-hi:  #2e2e3a;
					--m3-outline:     #49494f;
					--m3-outline-var: #31313a;
					--m3-primary:     #cac0ff;
					--m3-on-primary:  #302063;
					--m3-secondary:   #c8c3dc;
					--m3-on-surface:  #e5e1f0;
					--m3-on-surface-var: #c8c3d0;
					--m3-error:       #ffb4ab;
					--m3-on-error:    #690005;
					--m3-scrim:       rgba(0,0,0,0.6);

					/* status colors */
					--c-checking:  #2a3a5a;
					--c-pending:   #4a5568;
					--c-running:   #276749;
					--c-retrying:  #7a5c1a;
					--c-done:      #1a4731;
					--c-failed:    #7a1f1f;
					--c-missing:   #5c3d1a;
					--c-deleted:   #3a3a3a;
					--c-cancelled: #4a3a4a;
					--c-imported:  #1a3a4a;
				}

				html, body { height: 100%; background: var(--m3-bg); color: var(--m3-on-surface); }
				body { font-family: 'Google Sans', system-ui, -apple-system, sans-serif; }

				/* ── Material Symbols ── */
				.m3-icon {
					font-family: 'Material Symbols Rounded';
					font-size: 20px;
					font-weight: 400;
					font-style: normal;
					line-height: 1;
					letter-spacing: normal;
					text-transform: none;
					display: inline-block;
					white-space: nowrap;
					word-wrap: normal;
					direction: ltr;
					font-feature-settings: 'liga';
					-webkit-font-feature-settings: 'liga';
					-webkit-font-smoothing: antialiased;
					font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 20;
					user-select: none;
				}

				/* ── Header ── */
				header {
					display: flex; align-items: center; gap: .75rem;
					padding: .875rem 1.25rem;
					border-bottom: 1px solid var(--m3-outline-var);
					background: var(--m3-surface);
					position: sticky; top: 0; z-index: 20;
				}
				.logo { font-size: 1.1rem; font-weight: 600; color: var(--m3-primary); }

				/* ── Content ── */
				#content { padding: 1rem 1.25rem; max-width: 1100px; margin: 0 auto; }

				/* ── Add form ── */
				.add-form {
					display: flex; gap: .75rem; margin-bottom: 1rem;
					background: var(--m3-surface); border-radius: 16px;
					padding: .75rem 1rem;
					border: 1px solid var(--m3-outline-var);
				}
				.add-form input {
					flex: 1; background: transparent; border: none;
					color: var(--m3-on-surface); font-size: .9375rem;
					outline: none; min-width: 0;
				}
				.add-form input::placeholder { color: var(--m3-on-surface-var); }

				/* ── M3 Filled Button ── */
				.m3-btn {
					display: inline-flex; align-items: center; gap: .5rem;
					border: none; border-radius: 9999px; cursor: pointer;
					font-size: .875rem; font-weight: 500; padding: .5rem 1.25rem;
					transition: box-shadow .2s, filter .15s; min-height: 40px;
					white-space: nowrap;
				}
				.m3-btn-filled {
					background: var(--m3-primary); color: var(--m3-on-primary);
				}
				.m3-btn-filled:hover { filter: brightness(1.08); }

				/* ── Filter bar ── */
				.filter-bar {
					display: flex; flex-wrap: wrap; gap: .5rem;
					align-items: center; margin-bottom: .75rem;
				}
				.m3-search {
					flex: 1; min-width: 180px;
					background: var(--m3-surface-var); border: 1px solid var(--m3-outline-var);
					border-radius: 9999px; color: var(--m3-on-surface);
					font-size: .875rem; padding: .45rem 1rem; outline: none;
				}
				.m3-search:focus { border-color: var(--m3-primary); }
				.tag-filter-row { display: flex; flex-wrap: wrap; gap: .35rem; }

				/* ── M3 Chips ── */
				.m3-chip {
					display: inline-flex; align-items: center; gap: .3rem;
					background: transparent; border: 1px solid var(--m3-outline);
					border-radius: 9999px; color: var(--m3-on-surface-var);
					font-size: .8rem; padding: .2rem .75rem;
					cursor: pointer; transition: background .15s, color .15s;
					white-space: nowrap;
				}
				.m3-chip:hover { background: var(--m3-surface-var); color: var(--m3-on-surface); }
				.m3-chip.active {
					background: var(--m3-primary); color: var(--m3-on-primary);
					border-color: transparent;
				}
				.m3-chip-sm { font-size: .75rem; padding: .15rem .5rem; }
				.m3-chip-add {
					border-style: dashed; opacity: .6; padding: .15rem .5rem;
				}
				.m3-chip-add:hover { opacity: 1; }
				.chip-remove {
					background: transparent; border: none; cursor: pointer;
					color: inherit; font-size: .7rem; padding: 0; line-height: 1;
					opacity: .6; margin-left: .1rem;
				}
				.chip-remove:hover { opacity: 1; }

				/* ── Status badge colours (shared by chips и строками) ── */
				.badge-checking  { background: var(--c-checking);  color: #90aad0; }
				.badge-pending   { background: var(--c-pending);   color: #a0aec0; }
				.badge-running   { background: var(--c-running);   color: #68d391; }
				.badge-retrying  { background: var(--c-retrying);  color: #f6ad55; }
				.badge-done      { background: var(--c-done);      color: #68d391; }
				.badge-failed    { background: var(--c-failed);    color: #fc8181; }
				.badge-missing   { background: var(--c-missing);   color: #f6ad55; }
				.badge-deleted   { background: var(--c-deleted);   color: #718096; }
				.badge-cancelled { background: var(--c-cancelled); color: #c9a8e0; }
				.badge-hidden    { background: var(--m3-surface-var); color: var(--m3-outline); }
				.badge-imported  { background: var(--c-imported);   color: #63b3ed; }

				/* Статус-чип в строке — курсор pointer, hover чуть ярче */
				.m3-chip-status { cursor: pointer; }
				.m3-chip-status:hover { filter: brightness(1.2); }

				/* Скрытые строки скрыты по умолчанию; JS-фильтр управляет видимостью */
				.media-row.is-hidden { display: none; }

				/* Чип «скрытые» в фильтре — особый вид */
				.m3-chip-hidden { border: 1px dashed var(--m3-outline); }

				/* ── Media list ── */
				.media-list {
					display: flex; flex-direction: column; gap: .35rem;
				}
				.media-row {
					display: grid;
					grid-template-columns: 80px 1fr auto;
					gap: .75rem; align-items: center;
					background: var(--m3-surface);
					border: 1px solid var(--m3-outline-var);
					border-radius: 12px;
					padding: .75rem 1rem;
					transition: background .15s;
				}
				.media-row:hover { background: var(--m3-surface-var); }
				.media-row.status-running  { border-left: 3px solid #68d391; }
				.media-row.status-retrying { border-left: 3px solid #f6ad55; }
				.media-row.status-failed   { border-left: 3px solid #fc8181; }
				.media-row.status-lost     { border-left: 3px solid #f6ad55; opacity: .8; }

				/* Source column */
				.media-source {
					display: flex; flex-direction: column;
					align-items: center; gap: .3rem;
					color: var(--m3-on-surface-var); font-size: .7rem;
					text-align: center;
				}
				.favicon { border-radius: 3px; }
				.domain-label { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 72px; }

				/* Info column */
				.media-info { min-width: 0; }
				.media-title {
					font-size: .9rem; font-weight: 500; color: var(--m3-on-surface);
					overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
					margin-bottom: .3rem;
				}
				.media-meta {
					display: flex; flex-wrap: wrap; gap: .4rem; align-items: center;
				}
				.meta-size { font-size: .75rem; color: var(--m3-on-surface-var); }
				.meta-retry { font-size: .72rem; color: #f6ad55; }
				.tag-chips { display: flex; flex-wrap: wrap; gap: .25rem; align-items: center; }

				/* Actions column */
				.media-actions {
					display: flex; gap: .2rem; align-items: center; flex-shrink: 0;
				}

				/* ── M3 Icon Button ── */
				.m3-icon-btn {
					display: inline-flex; align-items: center; justify-content: center;
					width: 36px; height: 36px;
					background: transparent; border: none;
					border-radius: 9999px; cursor: pointer;
					color: var(--m3-on-surface-var);
					transition: background .15s, color .15s;
					text-decoration: none; flex-shrink: 0;
					position: relative; overflow: hidden;
				}
				.m3-icon-btn:hover {
					background: rgba(202,192,255,.1);
					color: var(--m3-on-surface);
				}
				.m3-icon-btn.m3-icon-btn-danger { color: var(--m3-error); }
				.m3-icon-btn.m3-icon-btn-danger:hover { background: rgba(255,180,171,.1); }

				/* State layer ripple */
				.m3-icon-btn::after {
					content: ''; position: absolute; inset: 0;
					border-radius: inherit; pointer-events: none;
					background: currentColor; opacity: 0;
					transition: opacity .1s;
				}
				.m3-icon-btn:active::after { opacity: .12; }

				/* ── Empty state ── */
				.m3-empty {
					display: flex; flex-direction: column; align-items: center;
					gap: 1rem; padding: 4rem 1rem;
					color: var(--m3-on-surface-var); text-align: center;
				}

				/* ── Player dialog ── */
				dialog#player-dialog {
					background: #000; border: none; border-radius: 16px;
					padding: 0; width: min(94vw, 920px); max-height: 94vh;
					overflow: hidden; margin: auto;
					box-shadow: 0 8px 48px rgba(0,0,0,.6);
				}
				dialog#player-dialog::backdrop { background: var(--m3-scrim); }
				.player-header {
					display: flex; justify-content: space-between; align-items: center;
					padding: .6rem .875rem; background: #111;
					color: var(--m3-on-surface);
				}
				.player-title {
					font-size: .875rem; font-weight: 500;
					overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
					flex: 1; margin-right: .5rem;
				}
				.player-close {
					display: inline-flex; align-items: center; justify-content: center;
					width: 32px; height: 32px; border-radius: 9999px;
					background: transparent; border: none;
					color: var(--m3-on-surface-var); cursor: pointer;
					transition: background .15s;
				}
				.player-close:hover { background: rgba(255,255,255,.1); }

				/* ── Log dialog ── */
				dialog#log-dialog {
					background: var(--m3-surface); border: 1px solid var(--m3-outline-var);
					border-radius: 16px; padding: 0;
					width: min(96vw, 860px); min-height: 60vh; max-height: 86vh;
					overflow: hidden; margin: auto;
					box-shadow: 0 8px 48px rgba(0,0,0,.6);
				}
				dialog#log-dialog[open] {
					display: flex; flex-direction: column;
				}
				dialog#log-dialog::backdrop { background: var(--m3-scrim); }
				.log-header {
					display: flex; justify-content: space-between; align-items: center;
					padding: .75rem 1rem; border-bottom: 1px solid var(--m3-outline-var);
					flex-shrink: 0;
				}
				.log-title {
					font-size: .9rem; font-weight: 500; color: var(--m3-on-surface);
					overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
					flex: 1; margin-right: .5rem;
				}
				#log-content {
					flex: 1; overflow: auto;
					margin: 0; padding: .875rem 1rem;
					font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
					font-size: .78rem; line-height: 1.55;
					color: #c8d0e0; white-space: pre-wrap; word-break: break-all;
					background: #0a0a0d;
				}

				/* ── Mobile ── */
				@media (max-width: 600px) {
					header { padding: .75rem; }
					#content { padding: .75rem; }
					.media-row {
						grid-template-columns: 56px 1fr;
						grid-template-rows: auto auto;
					}
					.media-actions {
						grid-column: 1 / -1;
						flex-wrap: wrap;
					}
					.m3-icon-btn { width: 32px; height: 32px; }
					.m3-icon { font-size: 18px; }
				}
			</style>
		</head>
		<body>
			<header>
				<span class="m3-icon" style="color:var(--m3-primary);font-size:24px;font-variation-settings:'FILL' 1">movie</span>
				<span class="logo">TalmorGo</span>
			</header>
			<main>
				{ children... }
			</main>

			<!-- Plyr popup -->
			<dialog id="player-dialog">
				<div class="player-header">
					<span class="player-title" id="player-title"></span>
					<button id="pip-btn" class="player-close" onclick="togglePiP()" title="Картинка в картинке" style="display:none">
						<span class="m3-icon">picture_in_picture</span>
					</button>
					<button class="player-close" onclick="closePlayer()">
						<span class="m3-icon">close</span>
					</button>
				</div>
				<video id="plyr-video" playsinline></video>
			</dialog>

			<!-- Log popup -->
			<dialog id="log-dialog">
				<div class="log-header">
					<span class="log-title" id="log-dialog-title">Лог скачивания</span>
					<button class="player-close" onclick="closeLog()">
						<span class="m3-icon">close</span>
					</button>
				</div>
				<pre id="log-content"></pre>
			</dialog>

			<script>
				// ── Plyr ──
				var plyrInstance;
				document.addEventListener('DOMContentLoaded', function() {
					plyrInstance = new Plyr('#plyr-video', {
						controls: ['play-large','play','progress','current-time','duration','mute','volume','fullscreen'],
						ratio: '16:9',
					});

					var pipBtn = document.getElementById('pip-btn');
					var video  = document.getElementById('plyr-video');

					// ── PiP (Picture-in-Picture) ──
					// iOS < 16 использует webkit API; iOS 16+ и остальные — стандартный W3C API.
					function _pipSupported() {
						return document.pictureInPictureEnabled ||
							(video.webkitSupportsPresentationMode &&
							 video.webkitSupportsPresentationMode('picture-in-picture'));
					}
					function _inPiP() {
						return document.pictureInPictureElement === video ||
							video.webkitPresentationMode === 'picture-in-picture';
					}
					function _setPipIcon(active) {
						pipBtn.querySelector('.m3-icon').textContent =
							active ? 'picture_in_picture_alt' : 'picture_in_picture';
					}
					if (_pipSupported()) pipBtn.style.display = '';

					// Стандартные события (Chrome, Firefox, Safari 16+)
					video.addEventListener('enterpictureinpicture', function() { _setPipIcon(true); });
					video.addEventListener('leavepictureinpicture', function() {
						_setPipIcon(false);
						if (!document.getElementById('player-dialog').open) plyrInstance.pause();
					});
					// WebKit-события (iOS < 16)
					video.addEventListener('webkitpresentationmodechanged', function() {
						var isPiP = video.webkitPresentationMode === 'picture-in-picture';
						_setPipIcon(isPiP);
						if (!isPiP && !document.getElementById('player-dialog').open) plyrInstance.pause();
					});

					// ── Авто-полноэкранный режим при повороте ──
					// screen.orientation появился в iOS Safari 16.4; старше — window.orientation.
					function _isLandscape() {
						if (screen.orientation) return screen.orientation.type.includes('landscape');
						return Math.abs(window.orientation || 0) === 90;
					}
					function _onOrientationChange() {
						if (!document.getElementById('player-dialog').open) return;
						setTimeout(function() {
							if (_isLandscape()) {
								if (!plyrInstance.fullscreen.active) plyrInstance.fullscreen.enter();
							} else {
								if (plyrInstance.fullscreen.active) plyrInstance.fullscreen.exit();
							}
						}, 150);
					}
					// Слушаем оба события — modern и legacy
					if (screen.orientation) screen.orientation.addEventListener('change', _onOrientationChange);
					window.addEventListener('orientationchange', _onOrientationChange);
				});

				function togglePiP() {
					var video = document.getElementById('plyr-video');
					// W3C API (iOS 16+, Chrome, Firefox, Safari desktop)
					if (document.pictureInPictureEnabled) {
						if (document.pictureInPictureElement) document.exitPictureInPicture();
						else video.requestPictureInPicture().catch(function(){});
					// WebKit API (iOS < 16)
					} else if (video.webkitSupportsPresentationMode &&
					           video.webkitSupportsPresentationMode('picture-in-picture')) {
						var mode = video.webkitPresentationMode === 'picture-in-picture' ? 'inline' : 'picture-in-picture';
						video.webkitSetPresentationMode(mode);
					}
				}
				function openPlayer(src, title) {
					document.getElementById('player-title').textContent = title || src;
					plyrInstance.source = { type: 'video', sources: [{ src: src, type: 'video/mp4' }] };
					document.getElementById('player-dialog').showModal();
					plyrInstance.play();
				}
				function closePlayer() {
					// PiP активен — не паузим, видео продолжает играть в мини-окне
					var video = document.getElementById('plyr-video');
					var inPiP = document.pictureInPictureElement === video ||
					            video.webkitPresentationMode === 'picture-in-picture';
					if (!inPiP) plyrInstance.pause();
					document.getElementById('player-dialog').close();
				}
				document.getElementById('player-dialog').addEventListener('click', function(e) {
					if (e.target === this) closePlayer();
				});

				// ── Log dialog ──
				function openLog(jobID, title) {
					document.getElementById('log-dialog-title').textContent = (title || 'Лог скачивания') + ' — лог';
					var pre = document.getElementById('log-content');
					pre.textContent = 'Загрузка…';
					document.getElementById('log-dialog').showModal();
					fetch('jobs/' + jobID + '/log')
						.then(function(r) { return r.ok ? r.text() : Promise.reject('Лог недоступен'); })
						.then(function(t) { pre.textContent = t || '(пусто)'; })
						.catch(function(e) { pre.textContent = String(e); });
				}
				function closeLog() {
					document.getElementById('log-dialog').close();
				}
				document.getElementById('log-dialog').addEventListener('click', function(e) {
					if (e.target === this) closeLog();
				});

				// ── File ops ──
				function renameFile(id, newName) {
					fetch('files/' + id, {
						method: 'PATCH',
						headers: {'Content-Type': 'application/json'},
						body: JSON.stringify({name: newName}),
					}).then(function() {
						htmx.ajax('GET', 'media/list', {target: '#media-inner', swap: 'outerHTML'});
					});
				}
				function renamePrompt(id, name) {
					var n = prompt('Новое имя:', name);
					if (n && n.trim()) renameFile(id, n.trim());
				}
				function copyPresigned(id, btn) {
					fetch('files/' + id + '/link', {method: 'POST'})
						.then(function(r) { return r.json(); })
						.then(function(d) {
							navigator.clipboard.writeText(d.url).then(function() {
								var icon = btn.querySelector('.m3-icon');
								if (icon) { icon.textContent = 'check'; setTimeout(function() { icon.textContent = 'link'; }, 1500); }
							});
						});
				}
				function copyOriginalURL(url) {
					navigator.clipboard.writeText(url);
				}

				// ── Tags ──
				function addTag(jobID) {
					var n = prompt('Новый тег:');
					if (!n || !n.trim()) return;
					fetch('jobs/' + jobID + '/tags', {
						method: 'POST',
						headers: {'Content-Type': 'application/json'},
						body: JSON.stringify({name: n.trim()}),
					}).then(function() {
						htmx.ajax('GET', 'media/list', {target: '#media-inner', swap: 'outerHTML'});
					});
				}

				// ── Client-side filtering ──
				var _activeTag = null;

				var _statusLabels = {
					'checking':'проверка…','pending':'ожидание','running':'скачивается',
					'retrying':'повтор','done':'готово','failed':'ошибка',
					'missing':'отсутствует','deleted':'удалён','cancelled':'отменено',
					'hidden':'скрытые','imported':'импортированы'
				};

				// Активировать статус-фильтр (вызывается из чипа внутри строки).
				function activateStatusFilter(tag) {
					var existing = document.querySelector('#status-chips [data-tag="' + tag + '"]');
					if (existing) { toggleTagFilter(existing); } else { setActiveTag(tag); applyFilters(); }
				}

				function toggleTagFilter(btn) {
					var tag = btn.dataset.tag;
					if (_activeTag === tag) {
						setActiveTag(null);
					} else {
						setActiveTag(tag);
					}
					applyFilters();
				}

				function setActiveTag(tag) {
					_activeTag = tag;
					// Снимаем active со всех фильтр-чипов.
					document.querySelectorAll('.tag-filter-row .m3-chip, #status-chips .m3-chip').forEach(function(b) {
						b.classList.toggle('active', b.dataset.tag === tag);
					});
				}

				function applyFilters() {
					var q = (document.getElementById('media-search') || {value:''}).value.toLowerCase();
					var showHidden = _activeTag === 'hidden';
					document.querySelectorAll('.media-row').forEach(function(row) {
						var isHiddenRow = row.classList.contains('is-hidden');
						// Режим «скрытые»: показываем только скрытые строки.
						if (showHidden) { row.style.display = isHiddenRow ? '' : 'none'; return; }
						// Обычный режим: скрытые строки не видны.
						if (isHiddenRow) { row.style.display = 'none'; return; }

						var text = (row.dataset.title + ' ' + row.dataset.url + ' ' + row.dataset.domain).toLowerCase();
						var tags = (row.dataset.tags || '').split(',');
						var matchSearch = !q || text.includes(q) || tags.some(function(t){ return t.toLowerCase().includes(q); });
						var matchTag = !_activeTag || tags.indexOf(_activeTag) >= 0;
						row.style.display = (matchSearch && matchTag) ? '' : 'none';
					});
				}

				// Строим чипы статусов из текущих данных.
				function rebuildStatusChips() {
					var seen = {}, order = [];
					document.querySelectorAll('.media-row').forEach(function(row) {
						var s = (row.dataset.tags || '').split(',')[0];
						if (s && !seen[s]) { seen[s] = true; order.push(s); }
					});
					// «скрытые» всегда последним.
					if (!seen['hidden']) order.push('hidden');

					var container = document.getElementById('status-chips');
					if (!container) return;
					container.innerHTML = '';
					order.forEach(function(s) {
						var btn = document.createElement('button');
						btn.className = 'm3-chip' + (s === 'hidden' ? ' m3-chip-hidden' : '');
						btn.dataset.tag = s;
						btn.textContent = _statusLabels[s] || s;
						if (_activeTag === s) btn.classList.add('active');
						btn.addEventListener('click', function() { toggleTagFilter(this); });
						container.appendChild(btn);
					});
				}

				// Переприменяем фильтр и пересобираем чипы после HTMX-обновления.
				document.body.addEventListener('htmx:afterSwap', function(e) {
					if (e.detail.target && e.detail.target.id === 'media-inner') {
						rebuildStatusChips();
						applyFilters();
					}
				});
				// Первый запуск.
				document.addEventListener('DOMContentLoaded', function() {
					rebuildStatusChips();
					applyFilters();
				});
			</script>
		</body>
	</html>
}
